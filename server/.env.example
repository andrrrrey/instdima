# ===== Основное =====
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
# Публичный HTTPS-адрес Mini App (обязателен для Telegram). Пример: https://plan.example.com
MINIAPP_URL=https://your-domain.example.com

# ===== Авторизация =====
# Секрет для подписи JWT-сессий (сгенерируйте длинную случайную строку)
JWT_SECRET=change-me-to-a-long-random-string
# Максимальный возраст Telegram initData, сек (по умолчанию сутки)
INITDATA_MAX_AGE_SEC=86400
# Локальная разработка без Telegram (НЕ включать в проде)
DEV_LOGIN=false

# ===== Telegram-бот =====
# Токен бота от @BotFather
BOT_TOKEN=
# long-polling (по умолчанию false) или webhook
BOT_USE_WEBHOOK=false
BOT_WEBHOOK_SECRET=

# Стартовый список пользователей: "telegramId:role:Имя", через запятую.
# role = owner | maker | customer | fashion
ALLOWLIST=111111111:owner:Ева, 222222222:maker:Кира, 333333333:customer:Дмитрий

# ===== База данных / очередь =====
DATABASE_URL=postgresql://contentplan:contentplan@postgres:5432/contentplan
REDIS_URL=redis://redis:6379

# ===== Claude через RouterAI (OpenAI-совместимый API) =====
ROUTERAI_BASE_URL=https://routerai.ru/v1
ROUTERAI_API_KEY=
CLAUDE_MODEL=claude-sonnet-4
# Модель для vision (по умолчанию = CLAUDE_MODEL)
CLAUDE_VISION_MODEL=
CLAUDE_MAX_TOKENS=1024
CLAUDE_TIMEOUT_MS=60000

# ===== Скрейпер Instagram (Apify) =====
# apify — реальный сервис; mock — заглушка для локальной разработки
SCRAPER_DRIVER=apify
APIFY_TOKEN=
APIFY_ACTOR=apify/instagram-scraper
SCRAPER_TIMEOUT_MS=120000

# ===== Хранилище медиа =====
# disk — на диске VPS; s3 — S3-совместимое хранилище
STORAGE_DRIVER=disk
STORAGE_DIR=/data/media
# Секрет для подписи ссылок на медиа
MEDIA_URL_SECRET=change-me-to-another-long-random-string
MEDIA_URL_TTL_SEC=3600
# --- если STORAGE_DRIVER=s3 ---
S3_BUCKET=
S3_REGION=ru-central1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ===== Дайджест обновлений Instagram =====
# cron-расписание еженедельной сборки (по умолчанию Пн 09:00)
DIGEST_CRON=0 9 * * 1
# Источники: "URL|type|Заголовок", через ; . type = rss | html
DIGEST_SOURCES=https://about.instagram.com/blog/rss|rss|Instagram Blog

# ===== ffmpeg =====
# путь к ffmpeg (если не в PATH)
FFMPEG_PATH=
